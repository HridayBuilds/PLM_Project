    "DATA_MAPPING_FROM_DATABASE": {
        "description": "How backend should map database tables to this JSON",
        "mappings": {
            "eco_id": "ECO.id",
            "eco_title": "ECO.title",
            "eco_type": "ECO.eco_type",
            "version_update": "ECO.version_update",
            "status": "ECO.status",
            "parent_product_cost_price": "PRODUCT.cost_price (where PRODUCT.id = ECO.product_id)",
            "bom_changes": "ECO_BOM_CHANGE rows joined with BOM_COMPONENT and PRODUCT",
            "product_changes": "ECO_PRODUCT_CHANGE rows for this ECO",
            "bom_operations": "BOM_OPERATION rows where BOM_OPERATION.bom_id = ECO.bom_id"
        }
    },

    "CHANGE_TYPES": {
        "modified": "Component quantity changed (old_quantity AND new_quantity have values)",
        "added": "New component added (old_quantity is null, new_quantity has value)",
        "removed": "Component removed (old_quantity has value, new_quantity is null)"
    }
}
